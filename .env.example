# Path to your OAuth client auth JSON (Google Docs publisher)
OAUTH_FILE_PATH=/path/to/your.oauth.client.json
# Redirect port for browser OAuth callback
OAUTH_REDIRECT_PORT=8080

# Jira configuration for jira_adapter.py
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_TOKEN=your-jira-api-token

# Polarion configuration for polarion_adapter.py
POLARION_BASE_URL=https://polarion.example.com
POLARION_PROJECT_ID=OSE
POLARION_TOKEN=your-polarion-bearer-token
